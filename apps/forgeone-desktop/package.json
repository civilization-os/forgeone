{
  "name": "forgeone-desktop",
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "description": "ForgeOne Open Agent Runtime Desktop GUI",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"electron .\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
