{
  "name": "forgeone-desktop",
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "description": "ForgeOne Open Agent Runtime Desktop GUI",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"electron .\"",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.forgeone.desktop",
    "productName": "ForgeOne",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "index.html"
    ],
    "extraResources": [
      {
        "from": "../../target/release/forgeone-server.exe",
        "to": "forgeone-server.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": null
    }
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^4.1.9"
  }
}
